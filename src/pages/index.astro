---

---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Joshua A Kim</title>

    <style>
      body {
        margin: 0;
        background: #5E81AC;
        color: white;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      }

      .wrapper {
        max-width: 1100px;
        min-height: 100vh;
        margin: 0 auto;
        padding: 80px 40px;

        display: flex;
        align-items: center;
        gap: 80px;
      }

      .photo img {
        width: 320px;
        border-radius: 10px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.25);
      }

      .content {
        max-width: 550px;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 0.4rem;
      }

      .subtitle {
        font-size: 1.2rem;
        opacity: 0.85;
        margin-bottom: 2rem;
      }

      p {
        line-height: 1.8;
        font-size: 1.1rem;
        margin-bottom: 1.4rem;
      }

      .contact {
        margin-top: 3rem;
      }

      @media (max-width: 900px) {
        .wrapper {
          flex-direction: column;
          text-align: center;
          gap: 50px;
          padding: 60px 30px;
        }

        .photo img {
          width: 260px;
        }
      }
    </style>
  </head>

  <body>
    <main class="wrapper">

      <div class="photo">
        <img src="/headshot.jpg" alt="Joshua A Kim" />
      </div>

      <div class="content">
        <h1>Joshua A Kim</h1>

        <p class="subtitle">
          Future home of my psychotherapy practice
        </p>

        <p>
          Welcome, and thank you for visiting.
        </p>

        <p>
          I am currently completing my MSW at The Ohio State University.
          More information about my practice will be available soon.
        </p>

        <p class="contact">
          Contact:<br />
          kimalexanderjoshua@gmail.com
        </p>
      </div>

    </main>
  </body>
</html>